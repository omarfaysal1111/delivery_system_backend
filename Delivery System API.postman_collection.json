        {
          "name": "Stripe webhook",
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Stripe-Signature",
                "value": "{{stripeSignature}}",
                "description": "Stripe signing secret validates this in production."
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{}"
